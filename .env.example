# Copy to .env and fill in. Real .env is gitignored.

# NWS api.weather.gov requires a descriptive User-Agent.
# Put your real email here so NOAA can reach you if needed.
NWS_USER_AGENT=WeatherPredictor/1.0 (vasudevatanmay@gmail.com)

# NCEI legacy CDO v2 token. OPTIONAL — we prefer the no-token
# Access Data Service. Only needed if you want CDO endpoints.
# Get one at https://www.ncdc.noaa.gov/cdo-web/token (instant).
NCEI_TOKEN=

# Visual Crossing free key (1000 records/day). OPTIONAL.
VISUALCROSSING_KEY=
